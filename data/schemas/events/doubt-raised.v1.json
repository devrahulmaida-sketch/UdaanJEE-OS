{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "doubt.raised.v1",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "studentId", "doubtId", "subject", "chapter"],
  "properties": {
    "eventId": {"type": "string"},
    "eventType": {"const": "doubt.raised"},
    "timestamp": {"type": "string", "format": "date-time"},
    "studentId": {"type": "string"},
    "doubtId": {"type": "string"},
    "subject": {"type": "string"},
    "chapter": {"type": "string"},
    "difficulty": {"type": "string", "enum": ["easy", "medium", "hard"]}
  }
}
